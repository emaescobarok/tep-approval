# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
# Service role: SOLO en el servidor / Edge Functions. Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- Notificaciones por email (Resend) ---
RESEND_API_KEY=re_xxxxxxxx
NOTIFICATIONS_FROM_EMAIL="Tep Agency <no-reply@tepagency.com>"

# Email de la agencia que recibe los avisos (comentarios/aprobaciones de clientes)
AGENCY_NOTIFICATIONS_EMAIL=equipo@tepagency.com

# Secreto compartido para invocar el worker de notificaciones (cron)
CRON_SECRET=poné-un-secreto-largo-aca

# URL pública de la app (para armar links en los emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
